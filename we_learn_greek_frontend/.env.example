# Local development — copy to .env
VITE_API_URL=http://localhost:8000/api
VITE_ENABLE_DEMO_DATA=true

# Vercel production (set in Vercel dashboard → Settings → Environment Variables)
# VITE_API_URL=https://your-api.onrender.com/api
# VITE_ENABLE_DEMO_DATA=false
#
# Then add your Vercel URL to backend CORS_ALLOWED_ORIGINS, e.g.:
# CORS_ALLOWED_ORIGINS=https://we-learn-greek.vercel.app
